{
  "name": "@pss/cli",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "bin": {
    "pss": "./dist/bin/pss.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "bundle": "esbuild src/bin/pss.ts --bundle --platform=node --format=cjs --target=node18 --outfile=dist/pss.cjs && chmod +x dist/pss.cjs",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@pss/core": "workspace:*",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.3"
  }
}
